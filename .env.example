# lexa environment variables — set these in the Vercel project (Production + Preview).
# Values are NOT committed. Copy to .env.local for local dev if needed.

# --- brain ---
ANTHROPIC_API_KEY=            # jonny's Anthropic key (pay-per-use)
LEXA_MODEL=claude-sonnet-5    # texting-loop model

# --- transport (Linq) ---
LINQ_API_KEY=                 # Linq Partner API bearer token
LEXA_PHONE_NUMBER=+13212973385   # lexa's Linq line (the "from")
LINQ_WEBHOOK_SECRET=          # Linq webhook signing secret (whsec_...); verifyLinq uses it
LINQ_ENFORCE_SIG=             # set "1" to reject bad signatures (default: log-only)

# --- memory (Supabase, project ref: tucemplfksloosrnhywt) ---
SUPABASE_URL=https://tucemplfksloosrnhywt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=    # currently the Supabase publishable key value (used server-side)

# --- who + where ---
OWNER_PHONE=+17073198190      # jonny's cell; lexa only answers this number
APP_BASE_URL=                 # deployed base URL (used to build OAuth redirect URIs)

# --- proactive engine ---
CRON_SECRET=                  # guards /api/cron/tick (Bearer header or ?key=)
SETTLE_MS=6000                # debounce window (ms) before replying

# --- integrations (per-service OAuth / keys) ---
GOOGLE_CLIENT_ID=             # Google OAuth (Gmail + Calendar + Drive)
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=          # Google Routes API (drive times)
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
NOTION_TOKEN=                 # Notion internal integration token
NOTION_MASTER_PLANNER_DB=     # (optional) Master Planner db id override

# --- GitHub Actions (repo secret, NOT app env) ---
# LEXA_TICK_URL = full /api/cron/tick URL incl. ?x-vercel-protection-bypass=...&key=...
#   the 15-min proactive pinger (.github/workflows/lexa-tick.yml) reads this
